---
// Hero: fondo con gradiente animado, título con gradiente en texto, CTA
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-6 pt-24"
>
  <!-- Animated gradient background -->
  <div
    class="absolute inset-0 opacity-90 animate-gradient"
    style="background: var(--gradient-hero);"
    aria-hidden="true"
  >
  </div>
  <div class="absolute inset-0 bg-[var(--color-surface)]/40" aria-hidden="true">
  </div>
  <!-- Optional blob shapes for depth -->
  <div
    class="animate-blob absolute -left-32 top-1/4 h-72 w-72 rounded-full opacity-30 blur-3xl"
    style="background: var(--color-accent);"
    aria-hidden="true"
  >
  </div>
  <div
    class="animate-blob absolute -right-24 top-1/2 h-96 w-96 rounded-full opacity-20 blur-3xl"
    style="background: var(--color-primary); animation-delay: -4s;"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <h1
      class="animate-fade-in-up mb-6 text-5xl font-bold tracking-tight sm:text-6xl md:text-7xl"
      style="font-family: var(--font-display); background: var(--gradient-text); -webkit-background-clip: text; background-clip: text; color: transparent; animation-delay: 0.1s;"
    >
      Hola, soy Jesús
    </h1>
    <p
      class="animate-fade-in-up mb-10 max-w-2xl text-xl text-zinc-300"
      style="animation-delay: 0.2s;"
    >
      Desarrollador con pasión por crear experiencias web rápidas y con
      personalidad.
    </p>
    <div
      class="animate-fade-in-up flex flex-wrap justify-center gap-4"
      style="animation-delay: 0.3s;"
    >
      <a
        href="#proyectos"
        class="rounded-xl bg-white px-8 py-3.5 text-sm font-semibold text-[var(--color-surface)] shadow-lg transition hover:scale-105 hover:shadow-xl"
      >
        Ver proyectos
      </a>
      <a
        href="#contacto"
        class="rounded-xl border-2 border-white/30 px-8 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition hover:border-white/60 hover:bg-white/10"
      >
        Contactar
      </a>
    </div>
  </div>
</section>
