---
// Hero: fondo con gradiente animado, título con gradiente en texto, CTA
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4 pt-24 sm:px-6 md:px-8"
>
  <!-- Animated gradient background -->
  <div
    class="absolute inset-0 opacity-90 animate-gradient"
    style="background: var(--gradient-hero);"
    aria-hidden="true"
  >
  </div>
  <div class="absolute inset-0 bg-[var(--color-surface)]/40" aria-hidden="true">
  </div>
  <!-- Optional blob shapes for depth -->
  <div
    class="animate-blob absolute -left-32 top-1/4 h-72 w-72 rounded-full opacity-30 blur-3xl"
    style="background: var(--color-accent);"
    aria-hidden="true"
  >
  </div>
  <div
    class="animate-blob absolute -right-24 top-1/2 h-96 w-96 rounded-full opacity-20 blur-3xl"
    style="background: var(--color-primary); animation-delay: -4s;"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-10 w-full max-w-4xl mx-auto text-center">
    <!-- Cabecera en 2 líneas, altura fija para no afectar al texto de abajo -->
    <div
      class="hero-header animate-fade-in-up mb-8"
      style="animation-delay: 0.1s;"
    >
      <h1
        class="hero-title text-5xl font-bold leading-tight tracking-tight sm:text-6xl md:text-7xl md:leading-tight"
        style="font-family: var(--font-display); background: var(--gradient-text); -webkit-background-clip: text; background-clip: text; color: transparent;"
      >
        <span class="hero-line-1">Hola, soy</span>
        <span class="hero-line-2">
          <span class="typing-wrapper"
            ><span id="hero-typing" aria-live="polite">Jesús</span><span
              class="typing-cursor"
              aria-hidden="true"></span></span
          >
        </span>
      </h1>
    </div>
    <p
      class="animate-fade-in-up mx-auto mb-10 max-w-2xl text-center text-xl leading-relaxed text-zinc-300"
      style="animation-delay: 0.2s;"
    >
      Desarrollador Frontend especializado en React. Código limpio,
      escalabilidad y en búsqueda de nuevos retos.
    </p>
    <div
      class="animate-fade-in-up flex flex-wrap justify-center gap-4"
      style="animation-delay: 0.3s;"
    >
      <a
        href="#proyectos"
        class="rounded-xl bg-white px-8 py-3.5 text-sm font-semibold text-[var(--color-surface)] shadow-lg transition hover:scale-105 hover:shadow-xl"
      >
        Ver proyectos
      </a>
      <a
        href="#contacto"
        class="rounded-xl border-2 border-white/30 px-8 py-3.5 text-sm font-semibold text-white backdrop-blur-sm transition hover:border-white/60 hover:bg-white/10"
      >
        Contactar
      </a>
    </div>
  </div>
</section>

<style>
  /* Cabecera: 2 líneas siempre, altura fija para no afectar al texto fijo de abajo */
  .hero-header {
    min-height: 4.5rem;
    overflow: hidden;
  }
  .hero-title {
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .hero-header {
      min-height: 5rem;
    }
  }
  @media (min-width: 768px) {
    .hero-header {
      min-height: 5.5rem;
    }
  }
  .hero-line-1 {
    display: block;
    text-align: center;
  }
  /* Segunda línea: flex para centrar siempre el texto que cambia */
  .hero-line-2 {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    text-align: center;
  }
  .typing-wrapper {
    display: inline-flex;
    justify-content: center;
    align-items: baseline;
    min-width: 10ch;
    min-height: 1.15em;
    max-width: 100%;
    text-align: center;
  }
  @media (min-width: 640px) {
    .typing-wrapper {
      min-width: 14ch;
    }
  }
  /* Cursor de escritura: barra vertical que parpadea */
  .typing-cursor {
    display: inline-block;
    width: 3px;
    height: 0.85em;
    margin-left: 2px;
    vertical-align: middle;
    background: var(--color-accent-light);
    border-radius: 1px;
    animation: cursor-blink 0.8s step-end infinite;
  }
  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  const phrases = ["Jesús", "desarrollador", "frontend", "React"];
  const el = document.getElementById("hero-typing");
  if (!el) throw new Error("hero-typing not found");

  const typeSpeed = 100;
  const pauseBeforeDelete = 2000;
  const deleteSpeed = 60;

  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function tick() {
    const current = phrases[phraseIndex];
    if (isDeleting) {
      el!.textContent = current.slice(0, charIndex - 1);
      charIndex--;
      if (charIndex === 0) {
        isDeleting = false;
        phraseIndex = (phraseIndex + 1) % phrases.length;
        setTimeout(tick, typeSpeed * 2);
        return;
      }
      setTimeout(tick, deleteSpeed);
    } else {
      el!.textContent = current.slice(0, charIndex + 1);
      charIndex++;
      if (charIndex === current.length) {
        isDeleting = true;
        setTimeout(tick, pauseBeforeDelete);
        return;
      }
      setTimeout(tick, typeSpeed);
    }
  }

  setTimeout(tick, 800);
</script>
